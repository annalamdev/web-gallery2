<style>
    .gallery-wrapper {
        display: flex;
        gap: 30px;
        align-items: flex-start;
    }

    .selection-panel {
        background-color: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        min-width: 240px;
    }

    .selection-panel h2 {
        font-size: 18px;
        margin-bottom: 15px;
        color: #2c3e50;
    }

    .selection-panel select {
        width: 100%;
        padding: 10px;
        font-size: 15px;
        border: 1px solid #ccc;
        border-radius: 5px;
        margin-bottom: 15px;
    }

    .submit-btn {
        display: block;
        width: 100%;
        padding: 10px;
        background-color: #2c3e50;
        color: white;
        border: none;
        border-radius: 5px;
        font-size: 16px;
        cursor: pointer;
    }

    .submit-btn:hover {
        background-color: #34495e;
    }

    .image-panel {
        flex: 1;
        background-color: white;
        border-radius: 8px;
        padding: 20px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        text-align: center;
    }

    .image-panel h2 {
        font-size: 20px;
        margin-bottom: 15px;
        color: #2c3e50;
    }

    .image-panel img {
        max-width: 100%;
        max-height: 500px;
        border-radius: 5px;
        cursor: pointer;
    }

    .image-panel .hint {
        margin-top: 10px;
        font-size: 13px;
        color: #888;
    }
</style>

{{> userbar }}

<form method="get" action="/">
    <div class="gallery-wrapper">

        <div class="selection-panel">
            <h2>Choose an Image</h2>

            <select name="image">
                <option value="default.jpg">-- Select an image --</option>
                {{#each images}}
                <option value="{{this.filename}}" {{#if this.selected}}selected{{/if}}>{{this.label}}</option>
                {{/each}}
            </select>

            <button type="submit" class="submit-btn">Submit</button>
        </div>

        <div class="image-panel">
            <h2>{{selectedLabel}}</h2>
            {{#if isDefault}}
                <img src="/images/{{selectedImage}}" alt="{{selectedLabel}}">
            {{else}}
                <a href="/order?image={{selectedImage}}">
                    <img src="/images/{{selectedImage}}" alt="{{selectedLabel}}">
                </a>
                <p class="hint">Click the image to order &amp; purchase</p>
            {{/if}}
        </div>

    </div>
</form>


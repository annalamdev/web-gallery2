<style>
    .order-wrapper {
        background-color: white;
        border-radius: 8px;
        padding: 30px;
        box-shadow: 0 2px 5px rgba(0,0,0,0.1);
        text-align: center;
    }

    .order-wrapper h2 {
        font-size: 24px;
        color: #2c3e50;
        margin-bottom: 20px;
    }

    .order-image {
        max-width: 100%;
        max-height: 400px;
        border-radius: 5px;
        margin-bottom: 20px;
    }

    .order-desc {
        font-size: 17px;
        color: #555;
        margin-bottom: 10px;
    }

    .order-price {
        font-size: 22px;
        color: #e74c3c;
        font-weight: bold;
        margin-bottom: 25px;
    }

    .order-buttons {
        display: flex;
        justify-content: center;
        gap: 20px;
    }

    .order-buttons button {
        padding: 12px 35px;
        font-size: 16px;
        border: none;
        border-radius: 5px;
        cursor: pointer;
        color: white;
    }

    .buy-btn {
        background-color: #27ae60;
    }

    .buy-btn:hover {
        background-color: #1e8449;
    }

    .cancel-btn {
        background-color: #c0392b;
    }

    .cancel-btn:hover {
        background-color: #922b21;
    }
</style>

{{> userbar }}

<div class="order-wrapper">
    <h2>Order &amp; Purchase</h2>

    <img class="order-image" src="/images/{{item.filename}}" alt="{{item.filename}}">

    <p class="order-desc">{{item.description}}</p>
    <p class="order-price">$ {{item.price}}</p>

    <div class="order-buttons">
        <form id="buyForm" method="post" action="/order/buy" style="display:inline;">
            <input type="hidden" name="filename" value="{{item.filename}}">
            <button type="button" class="buy-btn" onclick="alert('SOLD'); document.getElementById('buyForm').submit();">BUY</button>
        </form>

        <form id="cancelForm" method="post" action="/order/cancel" style="display:inline;">
            <input type="hidden" name="filename" value="{{item.filename}}">
            <button type="button" class="cancel-btn" onclick="alert('MAYBE NEXT TIME'); document.getElementById('cancelForm').submit();">CANCEL</button>
        </form>
    </div>
</div>
